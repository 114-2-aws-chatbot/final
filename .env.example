# 複製這個檔案為 .env，填入真實的值
# 注意：.env 已被 .gitignore 排除，不會上傳到 GitHub

# Discord Bot Token（Discord Developer Portal → Bot → Token）
DISCORD_TOKEN=your_discord_bot_token_here

# Discord Application ID（Discord Developer Portal → General Information）
DISCORD_APP_ID=your_application_id_here

# Discord Ed25519 公鑰（Discord Developer Portal → General Information）
DISCORD_PUBLIC_KEY=your_public_key_here

# AWS 設定（選填，有預設值）
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=amazon.nova-lite-v1
